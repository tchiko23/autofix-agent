OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b
OLLAMA_TEMPERATURE=0
OLLAMA_NUM_PREDICT=4096

FIX_TARGET_REPO=C:\path\to\your\repo

FORGE_PROVIDER=gitlab
FORGE_API_URL=https://gitlab.your-company.com/api/v4
FORGE_PROJECT_ID=your-org/your-repo
FORGE_BASE_URL=
FORGE_ASSIGNEE_USERNAME=
FORGE_REVIEWERS=
FORGE_LABELS=BUG,RUN
FORGE_DRAFT=true
FORGE_DESCRIPTION_APPEND=Merge request generee automatiquement a partir du fichier d'analyse.

DEFAULT_BASE_BRANCH=main
DEFAULT_TARGET_BRANCH=main
DEFAULT_SOURCE_BRANCH_PREFIX=hotfix/

JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_USER=
# (remplir avec ton email Atlassian)
CONFLUENCE_BASE_URL=
CONFLUENCE_SPACE_KEYS=

AGENT_MAX_FILES=12
AGENT_MAX_FILE_CHARS=12000
AGENT_WORKDIR=.work
AGENT_ENABLE_TIMING_LOGS=true

AGENT_TICKET_PREFIXES=RUN
AGENT_PRIORITY_REPO_PATHS=back,front,batch
AGENT_GENERATE_JUNIT_TESTS=true
AGENT_ANONYMIZE_PERSONAL_DATA=true
AGENT_DETERMINISTIC_APPLICATOR_ENABLED=true

AGENT_LLM_LIBRE_ENABLED=true
AGENT_LLM_LIBRE_MIN_VALIDATION_SCORE=40

AGENT_EXPLORATION_ENABLED=true
AGENT_EXPLORATION_MAX_TURNS=40
AGENT_EXPLORATION_MIN_VALIDATION_SCORE=40
AGENT_EXPLORATION_MAX_TOKENS=200000

AGENT_DEMO_MODE=true
FORGE_ALWAYS_SHIP_DIAGNOSTIC_MR=true
AGENT_BATCH_TICKET_TIMEOUT=0
OLLAMA_REQUEST_TIMEOUT=0

# v9.16.6 : selection du provider LLM
# - ollama (defaut) : tout reste local sur la local infrastructure, modele Ollama
# - anthropic : appelle l'API Claude (necessite ANTHROPIC_API_KEY dans secrets.env)
# - openai : appelle l'API OpenAI (necessite OPENAI_API_KEY dans secrets.env)
# ATTENTION : 'anthropic' et 'openai' envoient le contenu des prompts (qui peut
# contenir du your code) au cloud du fournisseur. Necessite un contrat
# Zero Data Retention valide on your side avant utilisation en production.
LLM_PROVIDER=ollama

# v9.16.6 : modeles externes (utilises si LLM_PROVIDER bascule)
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o

# v9.16.7 : commentaire automatique sur Jira apres creation MR
# Si JIRA_BASE_URL, JIRA_USER, JIRA_TOKEN sont remplis (dans secrets.env),
# le bundle poste un commentaire structure sur le ticket Jira d'origine.
# Le commentaire inclut : resume, lien MR, tableau RG, criteres, tests.
# Si JIRA_TOKEN est vide, la feature est silencieusement desactivee.
JIRA_COMMENT_ENABLED=true
JIRA_NOTIFY_ON_COMMENT=true
