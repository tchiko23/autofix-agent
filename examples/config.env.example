# =====================================================================
# fix-anomalie-agent — example configuration
#
# Copy this file to templates_external_config/config.env and edit values
# for your project. Secret values (tokens) go in secrets.env (see
# secrets.env.example).
# =====================================================================

# --- Required: where the bundle works ---
FIX_TARGET_REPO=/path/to/your/repo

# --- Required: GitLab forge ---
FORGE_API_URL=https://gitlab.your-company.com/api/v4
FORGE_BASE_URL=https://gitlab.your-company.com
FORGE_PROJECT_ID=12345

# --- Required: LLM provider (default: local Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b
# Alternative providers (uncomment + set keys in secrets.env):
# LLM_PROVIDER=anthropic
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# LLM_PROVIDER=openai
# OPENAI_MODEL=gpt-4o

# --- Optional: Jira back-comments ---
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_COMMENT_ENABLED=true
JIRA_NOTIFY_ON_COMMENT=true

# --- Quality gates ---
AGENT_MIN_PATCH_SCORE=65
AGENT_MIN_AUTOCOMMIT_SCORE=85
AGENT_LLM_LIBRE_ENABLED=true
AGENT_LLM_LIBRE_MIN_VALIDATION_SCORE=40
AGENT_EXPLORATION_ENABLED=true

# --- Cascade tuning ---
AGENT_MAX_FILES=12
AGENT_PRIORITY_REPO_PATHS=back,front,batch
AGENT_PACKAGE_PREFIXES=com.example.,com.example.subpkg.
AGENT_EXPLORATION_MAX_TURNS=40

# --- Branching ---
AGENT_SOURCE_BRANCH_PREFIX=hotfix/
AGENT_SOURCE_BRANCH_MODE=stable
AGENT_TARGET_BRANCH=main

# --- RAG (optional, heavy) ---
RAG_ENABLED=false
# RAG_INDEX_DIR=.chroma
# RAG_TOP_K=5
