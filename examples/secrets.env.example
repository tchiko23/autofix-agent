# =====================================================================
# fix-anomalie-agent — example secrets file
#
# Copy this file to templates_external_config/secrets.env and replace
# the placeholder values with your real tokens.
#
# IMPORTANT: this file must NEVER be committed to git. It is listed in
# .gitignore at the repo root.
# =====================================================================

# Required: GitLab API token with 'api' scope
# https://gitlab.your-company.com/-/user_settings/personal_access_tokens
FORGE_TOKEN=glpat-replace-with-your-real-token

# Optional: Jira credentials (only if you want back-comments on tickets)
# Get a token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_USER=your.email@your-company.com
JIRA_TOKEN=replace-with-your-atlassian-api-token

# Optional: alternate LLM provider API keys (if not using local Ollama)
# ANTHROPIC_API_KEY=sk-ant-replace-with-your-key
# OPENAI_API_KEY=sk-replace-with-your-key
